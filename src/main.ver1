// https://funduino.de/nr-32-der-rotary-encoder-ky-040
// zwischen grau (sleeve) und rot (tip) messe ich 15kOhm (oder 16kOhm) in eine Richtung und 24kOhm in die andere Richung beim Drehen des Encoders 
// 3.5kOhm für Mute
// https://forum.arduino.cc/t/steering-wheel-remote-audio-control/223878
// https://github.com/bigevtaylor/arduino-swc
// MCP 4151-104E (100kOhm) wird verwendet (Pin1->CS, Pin2->CLK, Pin3->SDO, Pin4->GND, Pin5->Pin 7(B)->GND, Pin 8->+5V)
// https://github.com/PaulusElektrus/Arduino_and_MCP4151/blob/master/MCP4151-U-Messung_Steckplatine.png (aber stimmt nicht ganz mit der Messung)

// ============================================================
// Pioneer SPH-DA77DAB - Drehencoder (Vol+/Vol-) + Taster (Mute)
// MCP4151-104 (100kΩ, SPI) + KY-040 Encoder
// Arduino Nano — PlatformIO
// ============================================================
//
// VERDRAHTUNG:
//   MCP4151:
//     Pin 1 (CS)   -> D9
//     Pin 2 (SCK)  -> D10
//     Pin 3 (SDI)  -> D11
//     Pin 4 (VSS)  -> GND
//     Pin 5 (PA0)  -> Pioneer SWC REM+  (weiss/braun)
//     Pin 6 (PW0)  -> Pioneer SWC REM+  (PA0 + PW0 brücken!)
//     Pin 7 (PB0)  -> GND
//     Pin 8 (VDD)  -> 5V
//
//   KY-040:
//     CLK -> D2   (Interrupt)
//     DT  -> D3
//     SW  -> D4   (Mute-Taster)
//     +   -> 5V
//     GND -> GND
//
//   Pioneer SWC-Kabel:
//     REM+  (weiss/braun) -> MCP4151 Pin 5+6
//     REM-  (schwarz)     -> GND
//
//   diesen MCP4151 unterstützt nicht open source output 04.04.2026
// ============================================================

#include <Arduino.h>
//#include <SPI.h>
//#include <MCP4151.h>
#include "mcp4151_soft_spi.h"

// LED Pin
constexpr uint8_t LED_PIN     =  13;  // Default built-in LED is on digital pin 13)

// Encoder Pins
constexpr uint8_t ENCODER_A   =  2;   // musst be Interrupt capable
constexpr uint8_t ENCODER_B   =  3;   // musst be Interrupt capable
constexpr uint8_t ENCODER_SW  =  4;   // SW = Mute

// MCP4151 Software-SPI Pins (alle frei wählbar, KEIN Pin 13!)
constexpr uint8_t MCP_CS_PIN   = A3; //9;   // Chip Select
constexpr uint8_t MCP_SCK_PIN  = A5; //10;  // SPI Clock
constexpr uint8_t MCP_DATA_PIN = A4; //11;  // Serial Data In/Out

// FET Pins
constexpr uint8_t FET_PIN   =  5;   // FET = OUT

// ============================================================
// Globale Objekte und Variablen
// ============================================================

// LED-Variablen
unsigned long ledOffTime = 0;
bool ledIsOn = false;

// ---- Timing --------------------------------------------------
constexpr uint16_t PULSE_MS      = 40; //50; //50 //150;  // Befehlsdauer ms
constexpr uint8_t  ENC_DEBOUNCE  =  10;  // Nur 1ms Entprellzeit  — für KY-040 ca. 30 (bounces heavily)
constexpr uint8_t  BTN_DEBOUNCE  =  50;  // Taster ms

//deepseek
// https://chat.deepseek.com/a/chat/s/3625d257-cad1-4079-ba06-69666c14984b
volatile int counter = 0;
volatile int potentiometerValue = 255;   // Startwert
volatile bool encoderChanged = false;
volatile uint8_t command;
// Entprellungs-Variablen
volatile unsigned long lastClkChange = 0;
volatile unsigned long lastDtChange = 0;
// Für die Flankenerkennung
volatile int lastClkState;
volatile int lastDtState;
// Für den MUTE-Button
bool     lastBtnState = HIGH;
uint32_t lastBtnTime  = 0;
bool     btnHandled    = false;  // verhindert Mehrfachauslösung

// --- MCP4151 Commands ---
constexpr uint8_t MCP4151_WRITE = 0x00;
constexpr uint8_t MCP4151_SHUTDOWN = 0x08;  // Wiper trennen (Hi-Z)
          
//const byte MUTE = 9;      // 3.5kOhm
//const byte VOL_UP = 41;   // 16kOhm
//const byte VOL_DOWN = 61; // 24kOhm

constexpr uint8_t POS_IDLE   = 255;  //181;  // ~71 kΩ  Ruhezustand
constexpr uint8_t POS_VOL_UP =  41;  // ~16 kΩ  Vol+
constexpr uint8_t POS_VOL_DOWN =  61;  // ~24 kΩ  Vol-
constexpr uint8_t POS_MUTE   =   9;  // ~ 3.5kΩ Mute -> ATT !

#define OUT_ON  digitalWrite(FET_PIN, HIGH);
#define OUT_OFF digitalWrite(FET_PIN, LOW);

// MCP4151 Objekt mit Software-SPI
MCP4151_SoftSPI potentiometer(MCP_CS_PIN, MCP_SCK_PIN, MCP_DATA_PIN);

// ---- Prototypen ----------------------------------------------
void flashLED(uint16_t duration);
void clkInterrupt();
void dtInterrupt();
void sendCommand(uint8_t pos);

void setup() {
  delay(500); // some microcontrollers reboot twice

  #ifdef DEBUG_MODE
    Serial.begin(115200);
    while (!Serial) {
      ; // Warte auf Serial-Port (nur relevant für bestimmte Boards)
    }
    Serial.println(F("Serial initialized."));
    Serial.println(F("setup(): begin"));
  #endif

  // MCP4151 via HARDWARE SPI
  //pinMode(MCP_CS_PIN, OUTPUT);
  //digitalWrite(MCP_CS_PIN, HIGH);
  //SPI.begin();
  //SPI.setDataMode(SPI_MODE0);
  //SPI.setBitOrder(MSBFIRST);
  //SPI.setClockDivider(SPI_CLOCK_DIV16); // ~1 MHz

  // Software-SPI initialisieren (kein hardware SPI!)
  potentiometer.begin();

  // LED
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, LOW);
  
  // Encoder
  pinMode(ENCODER_A, INPUT_PULLUP);
  pinMode(ENCODER_B, INPUT_PULLUP);

  // Mute-Taster
  pinMode(ENCODER_SW, INPUT_PULLUP);  // button to GND
  
  // Interrupts auf beide Pins für maximale Reaktionsfähigkeit
  attachInterrupt(digitalPinToInterrupt(ENCODER_A), clkInterrupt, CHANGE);
  attachInterrupt(digitalPinToInterrupt(ENCODER_B), dtInterrupt, CHANGE);
  
  // Speichere den Anfangszustand von CLK
  lastClkState = digitalRead(ENCODER_A);
  lastDtState = digitalRead(ENCODER_B);

  // Initialen Wert MPC4151 setzen
  potentiometer.setMid();

  pinMode(FET_PIN, OUTPUT);
  digitalWrite(FET_PIN, LOW);

  #ifdef DEBUG_MODE
    Serial.println(F("setup(): ready"));  
  #endif

  // Kurzer LED-Blink als Startbestätigung
  flashLED(200);

  #ifdef DEBUG_MODE
    Serial.println(F("Pioneer SWC bereit. Vol+/Vol-/Mute aktiv."));
  #endif

  //Serial.println("Rotary Encoder LED Blink with Button Reset");

  /* Serial.println("Widerstand auf 24k setzen -> VOL-");
  sendCommand(POS_VOL_DOWN); // 24kOhm
  Serial.println("Widerstand auf 16k setzen -> VOL+");
  sendCommand(POS_VOL_UP); // 16kOhm
  Serial.println("Widerstand auf 16k setzen -> VOL+");
  sendCommand(POS_VOL_UP); // 16kOhm */
}

void loop() {

  // LED automatisch ausschalten
  if (ledIsOn && (millis() >= ledOffTime)) {
    digitalWrite(LED_PIN, LOW);
    ledIsOn = false;
  }

  // ---- TEMPORÄR: Encoder-Rohwerte direkt ausgeben ------------
 /*  static uint8_t lastRawA = HIGH;
  static uint8_t lastRawB = HIGH;

  uint8_t rawA = digitalRead(ENCODER_A);
  uint8_t rawB = digitalRead(ENCODER_B);

  if (rawA != lastRawA || rawB != lastRawB) {
    Serial.print(F("A="));
    Serial.print(rawA);
    Serial.print(F(" B="));
    Serial.println(rawB);
    lastRawA = rawA;
    lastRawB = rawB;
  } */

  // ---- Encoder -----------------------------------------------
  // Nur ausgeben, wenn sich was geändert hat
  if (encoderChanged) {
    noInterrupts(); // Kurz Interrupts ausschalten für sicheren Zugriff
    #ifdef DEBUG_MODE
      int localCounter = counter;
    #endif
    encoderChanged = false;
    interrupts();
    
    #ifdef DEBUG_MODE
      Serial.print(F("Position: "));
      Serial.println(localCounter);
    #endif
    
    sendCommand(command);
    //potentiometer.writeValue(command);
    //OUT_ON
    //delay(PULSE_MS);
    //OUT_OFF
    //potentiometer.setMax();
    
    // Kurze LED-Rückmeldung für den Vorgang
    flashLED(5);
  }

  // ---- Mute-Taster (saubere Flankenauswertung) ---------------
  bool rawBtn = digitalRead(ENCODER_SW);

  // Änderung erkannt → Timer neu starten
  if (rawBtn != lastBtnState) {
    lastBtnTime = millis();
  }
  lastBtnState = rawBtn;

  // Erst nach Debounce-Zeit auswerten
  if ((millis() - lastBtnTime) > BTN_DEBOUNCE) {
    // Taster gedrückt (LOW) und noch nicht ausgeführt
    if (rawBtn == LOW && !btnHandled) {
      #ifdef DEBUG_MODE
        Serial.println(F("MUTE"));
      #endif
      detachInterrupt(digitalPinToInterrupt(ENCODER_A));
      detachInterrupt(digitalPinToInterrupt(ENCODER_B));
      sendCommand(POS_MUTE);
      flashLED(5);
      btnHandled = true;  // nicht nochmals auslösen bis losgelassen
    }
    // Taster losgelassen (HIGH) → 400ms Pause für Encoder
    if (rawBtn == HIGH && btnHandled) {
      #ifdef DEBUG_MODE
        Serial.println(F("BUTTON RELEASED"));
      #endif
      btnHandled = false;
      //detachInterrupt(digitalPinToInterrupt(ENCODER_A));
      //detachInterrupt(digitalPinToInterrupt(ENCODER_B));
      delay(400);
      attachInterrupt(digitalPinToInterrupt(ENCODER_A), clkInterrupt, CHANGE);
      attachInterrupt(digitalPinToInterrupt(ENCODER_B), dtInterrupt, CHANGE);
    }
  }
}

// ============================================================
// LED-Feedback Funktion
// ============================================================
void flashLED(uint16_t durationMs) {
  digitalWrite(LED_PIN, HIGH);
  ledIsOn = true;
  ledOffTime = millis() + durationMs;
}

void clkInterrupt() {
  unsigned long now = micros(); // micros() für genauere Zeitmessung!
  
  // Entprellung: Nur reagieren, wenn letzte Änderung länger her ist
  if (((now - lastClkChange) > ENC_DEBOUNCE * 1000) & !btnHandled ){
    int clkState = digitalRead(ENCODER_A);
    int dtState = digitalRead(ENCODER_B);
    
    // Auf fallende Flanke prüfen (HIGH -> LOW)
    if (lastClkState == HIGH && clkState == LOW) {
      // Jetzt ist der entscheidende Moment!
      if (dtState == HIGH) {
        counter--;
        command = POS_VOL_DOWN;
        //sendCommand(POS_VOL_DOWN);
      } else {
        counter++;
        command = POS_VOL_UP;
      }
      encoderChanged = true;
    }
    
    lastClkState = clkState;
    lastClkChange = now;
  }
}

void dtInterrupt() {
  // DT-Interrupt wird nur für die Entprellung benötigt
  unsigned long now = micros();
  if (((now - lastDtChange) > ENC_DEBOUNCE * 1000) & !btnHandled) {
    lastDtState = digitalRead(ENCODER_B);
    lastDtChange = now;
  }
}

// ==============================================================
// Befehl senden: kurzer Impuls, dann Ausgang offen
void sendCommand(uint8_t pos) {
  potentiometer.writeValue(pos);
  //delay(1);
  delayMicroseconds(5);
  OUT_ON
  delay(PULSE_MS);
  //setWiper(POS_IDLE);
  OUT_OFF
  //setIdle();   // statt setWiper(POS_IDLE)
  //potentiometer.setMax();
  //delay(1);
  delayMicroseconds(5);
}
